{
    "name": "nikium-ide",
    "version": "0.0.0",
    "private": true,
    "packageManager": "pnpm@10.32.1",
    "scripts": {
        "dev": "pnpm --filter frontend dev",
        "dev:backend": "cd backend && go run ./cmd/server/main.go",
        "dev:worker": "cd worker && go run ./cmd/main.go",
        "build": "pnpm --filter frontend build",
        "build:backend": "cd backend && go build -o bin/server ./cmd/server/main.go",
        "build:worker": "cd worker && go build -o bin/worker ./cmd/main.go"
    },
    "devDependencies": {
        "turbo": "latest"
    }
}
